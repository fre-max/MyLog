{
  "version": 3,
  "routes": [
    {
      "src": "^(?:/(.*))$",
      "headers": {
        "x-original-path": "/$1"
      },
      "continue": true
    },
    {
      "src": "^/(?:(.+)/)?index(?:\\.html)?/?$",
      "headers": {
        "Location": "/$1"
      },
      "status": 308
    },
    {
      "src": "^/(.*)\\.html/?$",
      "headers": {
        "Location": "/$1"
      },
      "status": 308
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/api/analyze$",
      "dest": "/api_analyze_ltycvv",
      "check": true
    },
    {
      "src": "^/api/telegram$",
      "dest": "/api_telegram_1ryin9",
      "check": true
    }
  ],
  "overrides": {}
}